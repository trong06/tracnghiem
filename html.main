<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Công Cụ Ôn Thi Trắc Nghiệm</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f7f6; color: #333; line-height: 1.6; padding: 20px; }
        .quiz-container { max-width: 800px; margin: 0 auto; background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        h1 { text-align: center; color: #0056b3; }
        .question-block { margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
        .question-text { font-weight: bold; margin-bottom: 10px; font-size: 1.1em; }
        .option { display: block; margin-bottom: 8px; cursor: pointer; padding: 8px; border-radius: 4px; transition: background 0.2s; }
        .option:hover { background: #f0f8ff; }
        input[type="radio"] { margin-right: 10px; }
        .btn-submit { display: block; width: 100%; padding: 12px; background: #28a745; color: white; border: none; border-radius: 4px; font-size: 1.1em; cursor: pointer; font-weight: bold; margin-top: 20px;}
        .btn-submit:hover { background: #218838; }
        .result-msg { margin-top: 10px; font-weight: bold; display: none; padding: 10px; border-radius: 4px;}
        .correct { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .incorrect { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        #final-score { margin-top: 20px; font-size: 1.2em; font-weight: bold; text-align: center; color: #0056b3; }
    </style>
</head>
<body>

<div class="quiz-container">
    <h1>Ôn Tập Cơ Sở Đo Lường Điện Tử</h1>
    <div id="quiz-body">
        </div>
    <button class="btn-submit" onclick="checkAnswers()">Nộp Bài & Xem Kết Quả</button>
    <div id="final-score"></div>
</div>

<script>
    // DỮ LIỆU CÂU HỎI (Bạn có thể copy và thêm các câu khác của bạn vào đây theo đúng cấu trúc)
    const quizData = [
        {
            id: 1,
            question: "1. Đơn vị đo điện cảm trong hệ SI là gì?",
            options: { a: "Fara (F)", b: "Watt (W)", c: "Henry (H)", d: "Ohm (Ω)" },
            correct: "c"
        },
        {
            id: 2,
            question: "2. Điện áp là gì trong đo lường điện?",
            options: { a: "Lực đẩy điện", b: "Sự chênh lệch điện thế", c: "Số electron trong mạch", d: "Tốc độ dòng điện" },
            correct: "b"
        },
        {
            id: 3,
            question: "3. Chức năng của dây đo trong dao động ký là gì?",
            options: { a: "Mở rộng giới hạn đo", b: "Bổ chính tần số", c: "Kết nối nguồn tín hiệu với máy đo", d: "Giảm nhiễu" },
            correct: "c"
        },
        {
            id: 4,
            question: "4. Cơ cấu chỉ thị từ điện hoạt động với dòng nào?",
            options: { a: "Dòng xoay chiều", b: "Dòng một chiều", c: "Cả hai loại", d: "Không xác định" },
            correct: "b"
        },
        {
            id: 5,
            question: "5. Điện trở thụ động là điện trở:",
            options: { a: "Có mang năng lượng điện", b: "Không mang năng lượng điện", c: "Có dòng điện chạy qua", d: "Có điện áp định mức" },
            correct: "b"
        }
    ];

    const quizBody = document.getElementById('quiz-body');

    // Hàm render câu hỏi ra giao diện
    function renderQuiz() {
        quizData.forEach((q, index) => {
            const block = document.createElement('div');
            block.className = 'question-block';
            
            let optionsHtml = '';
            for (const [key, value] of Object.entries(q.options)) {
                optionsHtml += `
                    <label class="option">
                        <input type="radio" name="q${q.id}" value="${key}"> 
                        ${key.toUpperCase()}. ${value}
                    </label>
                `;
            }

            block.innerHTML = `
                <div class="question-text">${q.question}</div>
                ${optionsHtml}
                <div class="result-msg" id="msg-q${q.id}"></div>
            `;
            quizBody.appendChild(block);
        });
    }

    // Hàm chấm điểm
    function checkAnswers() {
        let score = 0;
        quizData.forEach(q => {
            const selected = document.querySelector(`input[name="q${q.id}"]:checked`);
            const msgBox = document.getElementById(`msg-q${q.id}`);
            msgBox.style.display = 'block';

            if (selected) {
                if (selected.value === q.correct) {
                    score++;
                    msgBox.className = 'result-msg correct';
                    msgBox.innerText = '✔️ Chính xác!';
                } else {
                    msgBox.className = 'result-msg incorrect';
                    msgBox.innerText = `❌ Sai. Đáp án đúng là: ${q.correct.toUpperCase()}. ${q.options[q.correct]}`;
                }
            } else {
                msgBox.className = 'result-msg incorrect';
                msgBox.innerText = `⚠️ Bạn chưa chọn đáp án. Đáp án đúng là: ${q.correct.toUpperCase()}. ${q.options[q.correct]}`;
            }
        });

        document.getElementById('final-score').innerText = `Bạn đã đúng ${score} / ${quizData.length} câu!`;
    }

    // Chạy render khi tải trang
    renderQuiz();
</script>

</body>
</html>
